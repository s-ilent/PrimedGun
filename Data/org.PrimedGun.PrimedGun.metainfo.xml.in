<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.PrimedGun.PrimedGun</id>
  <name>PrimedGun</name>
  <developer id="org.primedgun">
    <name>PrimedGun Project</name>
  </developer>
  <summary>Metroid Prime VR launcher built on Dolphin ReduX</summary>
  <metadata_license>CC-BY-SA-3.0</metadata_license>
  <project_license>GPL-2.0+</project_license>
  <content_rating type="oars-1.0"/>
  <description>
    <p>PrimedGun is a Dolphin ReduX-based build focused on improving the Metroid Prime VR experience. It provides a dedicated desktop interface, OpenXR support, VR-oriented controls, in-headset settings, arm cannon tracking, height calibration, and Metroid Prime setup guidance.</p>
    <p>Users must provide their own legally owned Metroid Prime GameCube game file and configure a working OpenXR runtime such as SteamVR or Monado.</p>
  </description>
  <launchable type="desktop-id">org.PrimedGun.PrimedGun.desktop</launchable>
  <provides>
    <binary>PrimedGun</binary>
    <id>org.PrimedGun.PrimedGun.desktop</id>
  </provides>
  <releases>
    <release version="${DOLPHIN_WC_DESCRIBE}" date="${DOLPHIN_WC_BUILD_DATE}"/>
  </releases>
  <url type="vcs-browser">https://github.com/Nobbie248/PrimedGun</url>
</component>
